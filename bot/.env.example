# Telegram
BOT_TOKEN=your_telegram_bot_token_from_@BotFather
ADMIN_TELEGRAM_ID=   # @hotamov_n ning raqamli ID si (u botga /start yuborganda konsolda chiqadi yoki @userinfobot)

# Firebase — ikki usul: 1) JSON fayl (serverda tavsiya), 2) .env da key
# 1) JSON fayl: service account JSON ni serverga yuklab, masalan bot/serviceAccount.json qiling va:
# FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccount.json
# 2) Yoki quyidagi 3 ta o'zgaruvchini to'ldiring (PRIVATE_KEY da \n larni saqlang)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
